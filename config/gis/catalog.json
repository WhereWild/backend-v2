  "categories": [
    {
      "name": "bioclimate",
      "display_name": "Bioclimatic",
      "description": "Bioclimatic variables derived from monthly temperature and precipitation to capture annual trends, seasonality, and extremes for ecological modeling. Includes WorldClim 2.1 (BIO1–BIO19) and CHELSA-BIOCLIM+ variables.",
      "source_ids": ["worldclim_2_1", "chelsa_bioclim_plus", "koppen_geiger_beck_2023"],
      "layers": [
        { "id": "bio_1",  "source_ids": ["worldclim_2_1"], "code": "BIO1",  "display_name": "Annual Mean Temperature",              "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_2",  "source_ids": ["worldclim_2_1"], "code": "BIO2",  "display_name": "Mean Diurnal Range",                    "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_3",  "source_ids": ["worldclim_2_1"], "code": "BIO3",  "display_name": "Isothermality",                         "units": "ratio ×100",            "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_4",  "source_ids": ["worldclim_2_1"], "code": "BIO4",  "display_name": "Temperature Seasonality",               "units": "standard deviation ×100","region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_5",  "source_ids": ["worldclim_2_1"], "code": "BIO5",  "display_name": "Max Temperature of Warmest Month",      "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_6",  "source_ids": ["worldclim_2_1"], "code": "BIO6",  "display_name": "Min Temperature of Coldest Month",      "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_7",  "source_ids": ["worldclim_2_1"], "code": "BIO7",  "display_name": "Temperature Annual Range",              "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_8",  "source_ids": ["worldclim_2_1"], "code": "BIO8",  "display_name": "Mean Temperature of Wettest Quarter",   "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_9",  "source_ids": ["worldclim_2_1"], "code": "BIO9",  "display_name": "Mean Temperature of Driest Quarter",    "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_10", "source_ids": ["worldclim_2_1"], "code": "BIO10", "display_name": "Mean Temperature of Warmest Quarter",   "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_11", "source_ids": ["worldclim_2_1"], "code": "BIO11", "display_name": "Mean Temperature of Coldest Quarter",   "units": "°C",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_12", "source_ids": ["worldclim_2_1"], "code": "BIO12", "display_name": "Annual Precipitation",                  "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_13", "source_ids": ["worldclim_2_1"], "code": "BIO13", "display_name": "Precipitation of Wettest Month",        "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_14", "source_ids": ["worldclim_2_1"], "code": "BIO14", "display_name": "Precipitation of Driest Month",         "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_15", "source_ids": ["worldclim_2_1"], "code": "BIO15", "display_name": "Precipitation Seasonality",             "units": "coefficient",           "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_16", "source_ids": ["worldclim_2_1"], "code": "BIO16", "display_name": "Precipitation of Wettest Quarter",      "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_17", "source_ids": ["worldclim_2_1"], "code": "BIO17", "display_name": "Precipitation of Driest Quarter",       "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_18", "source_ids": ["worldclim_2_1"], "code": "BIO18", "display_name": "Precipitation of Warmest Quarter",      "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "bio_19", "source_ids": ["worldclim_2_1"], "code": "BIO19", "display_name": "Precipitation of Coldest Quarter",      "units": "mm",                    "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "koppen_geiger", "source_ids": ["koppen_geiger_beck_2023"], "code": "KOPPEN_GEIGER", "display_name": "Köppen-Geiger Classes", "units": "class id", "region_root": "regions", "region_size": 10, "filename_template": "koppen_geiger.tif", "value_type": "categorical" },
        { "id": "clt",  "source_ids": ["chelsa_bioclim_plus"], "code": "CLT",      "display_name": "Cloud Area Fraction",                             "units": "%",       "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "rsds", "source_ids": ["chelsa_bioclim_plus"], "code": "RSDS",     "display_name": "Surface Downwelling Shortwave Radiation",         "units": "W/m^2",   "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "scd",  "source_ids": ["chelsa_bioclim_plus"], "code": "SCD",      "display_name": "Snow Cover Days",                                 "units": "days/year","region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "sfc",  "source_ids": ["chelsa_bioclim_plus"], "code": "SFC_WIND", "display_name": "Near-Surface Wind Speed (10m)",                   "units": "m/s",     "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" },
        { "id": "swe",  "source_ids": ["chelsa_bioclim_plus"], "code": "SWE",      "display_name": "Snow Water Equivalent",                           "units": "kg/m^2/year","region_root": "regions","region_size": 10,"filename_template": "{id}.tif","value_type": "numeric" },
        { "id": "vpd",  "source_ids": ["chelsa_bioclim_plus"], "code": "VPD",      "display_name": "Vapor Pressure Deficit",                          "units": "Pa",      "region_root": "regions", "region_size": 10, "filename_template": "{id}.tif", "value_type": "numeric" }
      ]
